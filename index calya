    <!-- JAVASCRIPT -->
    <script>
        // FAQ Accordion
        const faqItems = document.querySelectorAll('.faq-item');
        faqItems.forEach(item => {
            const question = item.querySelector('.faq-q');
            question.addEventListener('click', () => {
                faqItems.forEach(otherItem => { if (otherItem !== item) otherItem.classList.remove('active'); });
                item.classList.toggle('active');
            });
        });

        // Toggle Read More
        function toggleReadMore(id, btn) {
            const content = document.getElementById(id);
            if (content.style.maxHeight) {
                content.style.maxHeight = null;
                btn.innerHTML = btn.getAttribute('data-closed') || 'Baca Selengkapnya <i class="ri-arrow-down-s-line"></i>';
            } else {
                content.style.maxHeight = content.scrollHeight + "px";
                if(!btn.getAttribute('data-closed')) btn.setAttribute('data-closed', btn.innerHTML);
                btn.innerHTML = 'Tutup <i class="ri-arrow-up-s-line"></i>';
            }
        }

        // Lite YouTube Embed
        function playYouTube(div, videoId) {
            const iframe = document.createElement('iframe');
            iframe.setAttribute('allowfullscreen', '');
            iframe.setAttribute('allow', 'accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture');
            iframe.setAttribute('frameborder', '0');
            iframe.setAttribute('loading', 'lazy');
            iframe.src = 'https://www.youtube.com/embed/' + videoId + '?rel=0&showinfo=0&autoplay=1';
            div.parentNode.replaceChild(iframe, div);
        }

        // Header Dropdown Model
        function toggleModelDropdown() {
            document.getElementById('dropdown-model-header').classList.toggle('show');
        }
        window.onclick = function(event) {
            if (!event.target.closest('.header-col-4')) {
                const dd = document.getElementById('dropdown-model-header');
                if(dd && dd.classList.contains('show')) dd.classList.remove('show');
            }
            if (!event.target.closest('.nav-item')) {
                const sd = document.getElementById('simulasi-dropdown');
                if(sd && sd.style.display === 'block') sd.style.display = 'none';
            }
        }

        // Scroll Function
        function scrollToSection(id) {
            document.getElementById(id).scrollIntoView({ behavior: 'smooth' });
        }

        // Simulasi Dropdown Logic
        function toggleSimulasiDropdown(e) {
            e.stopPropagation();
            const dropdown = document.getElementById('simulasi-dropdown');
            if (dropdown.style.display === 'block') {
                dropdown.style.display = 'none';
            } else {
                dropdown.style.display = 'block';
            }
        }

        function sendWA(model) {
            const phone = '6282316092405';
            const text = encodeURIComponent(`Saya ingin Simulasi Kredit ${model}`);
            window.open(`https://wa.me/${phone}?text=${text}`, '_blank');
        }

        // Dynamic Date
        const now = new Date();
        const monthNames = ["Januari", "Februari", "Maret", "April", "Mei", "Juni", "Juli", "Agustus", "September", "Oktober", "November", "Desember"];
        document.querySelectorAll('.dynamic-date').forEach(el => { el.innerText = `30 ${monthNames[now.getMonth()]} ${now.getFullYear()}`; });
    </script>
